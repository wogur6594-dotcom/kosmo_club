<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.club.app.club.board.ClubBoardMapper">

    <!-- 게시글 개수 -->
    <select id="getCount" resultType="long">
        SELECT COUNT(*)
        FROM "TB_CLUB_BOARD"
    </select>

    <!-- 게시글 목록 -->
    <select id="list" resultType="ClubBoardDTO">
        SELECT *
        FROM "TB_CLUB_BOARD"
        ORDER BY "BOARD_NUM" DESC
        LIMIT #{perPage}
        OFFSET #{startNum}
    </select>

    <!-- 게시글 상세 -->
    <select id="detail"
        parameterType="ClubBoardDTO"
        resultType="ClubBoardDTO">

        SELECT *
        FROM "TB_CLUB_BOARD"
        WHERE "BOARD_NUM" = #{boardNum}

    </select>

    <!-- 게시글 작성 -->
    <insert id="create"
        parameterType="ClubBoardDTO">

        INSERT INTO "TB_CLUB_BOARD"
        (
            "CLUB_NUM",
            "BOARD_TITLE",
            "BOARD_CONTENTS",
            "BOARD_CATEGORY",
            "BOARD_WRITER"
        )
        VALUES
        (
            #{clubNum},
            #{boardTitle},
            #{boardContents},
            #{boardCategory},
            #{boardWriter}
        )

    </insert>

    <!-- 수정 -->
    <update id="update"
        parameterType="ClubBoardDTO">

        UPDATE "TB_CLUB_BOARD"
        SET
            "BOARD_TITLE" = #{boardTitle},
            "BOARD_CONTENTS" = #{boardContents},
            "BOARD_CATEGORY" = #{boardCategory}
        WHERE "BOARD_NUM" = #{boardNum}

    </update>

    <!-- 삭제 -->
    <delete id="delete"
        parameterType="ClubBoardDTO">

        DELETE FROM "TB_CLUB_BOARD"
        WHERE "BOARD_NUM" = #{boardNum}

    </delete>

</mapper>